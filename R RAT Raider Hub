   end,
})
local ToolTab = Window:Tab({ Name = "Tool", Icon = "nil" })
local ToolSection = ToolTab:Section({ Name = "Utilities" })

local cctpEnabled = false
ToolSection:Toggle({
   Name = "Ctrl + Click to Teleport",
   Default = false,
   Callback = function(val) cctpEnabled = val end,
})

UIS.InputBegan:Connect(function(input, gp)
   if gp or not cctpEnabled then return end
   if input.UserInputType == Enum.UserInputType.MouseButton1 and (UIS:IsKeyDown(Enum.KeyCode.LeftControl) or UIS:IsKeyDown(Enum.KeyCode.RightControl)) then
      if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
         player.Character.HumanoidRootPart.CFrame = CFrame.new(player:GetMouse().Hit.Position + Vector3.new(0, 3, 0))
      end
   end
end)

ToolSection:Button({
   Name = "Alt Click Delete",
   Callback = function()
      _G.AltDeleteEnabled = not _G.AltDeleteEnabled 
      if not _G.AltDelConn then
          _G.AltDelConn = player:GetMouse().Button1Down:Connect(function()
              if _G.AltDeleteEnabled and UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then
                  if player:GetMouse().Target then player:GetMouse().Target:Destroy() end
              end
          end)
      end
      Library:Notify({Text = "Alt-Delete: " .. tostring(_G.AltDeleteEnabled), Duration = 2})
   end,
})

