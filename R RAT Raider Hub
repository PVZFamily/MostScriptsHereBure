local MainTab = Window:Tab({ Name = "Main Page", Icon = "rbxassetid://11396131982" })
local MainSection = MainTab:Section({ Name = "Main stuff" })

local function getHumanoid()
   return player.Character and player.Character:FindFirstChildOfClass("Humanoid")
end

local function applySpeed()
   local humanoid = getHumanoid()
   if humanoid then humanoid.WalkSpeed = isSpeedEnabled and currentSpeed or 16 end
end

local function applyJump()
   local humanoid = getHumanoid()
   if humanoid then 
      humanoid.UseJumpPower = true
      humanoid.JumpPower = isJumpEnabled and currentJumpPower or 50 
   end
end

player.CharacterAdded:Connect(function()
    task.wait(0.5)
    applySpeed()
    applyJump()
end)

