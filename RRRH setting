local isSpeedEnabled = false
local isJumpEnabled = false
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Aimbot Settings
local AimbotEnabled = false
local TargetPart = "Head"
local FOV = 400

local function GetClosestPlayer()
    local ClosestPlayer = nil
    local ShortestDistance = FOV

    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and Player.Character and Player.Character:FindFirstChild(TargetPart) then
            local Character = Player.Character
            local Part = Character[TargetPart]

            local ScreenPoint, Visible = Camera:WorldToViewportPoint(Part.Position)
            if Visible then
                local Distance = (Vector2.new(ScreenPoint.X, ScreenPoint.Y) - 
                    Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude

                if Distance < ShortestDistance then
                    ShortestDistance = Distance
                    ClosestPlayer = Player
                end
            end
        end
    end

    return ClosestPlayer
end

RunService.RenderStepped:Connect(function()
    if AimbotEnabled then
        local Target = GetClosestPlayer()
        if Target and Target.Character and Target.Character:FindFirstChild(TargetPart) then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Character[TargetPart].Position)
        end
    end
end)

local Library
repeat
    -- 1. Try to download and run the library script
    local success, result = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/Loco-CTO/UI-Library/main/VisionLibV2/source.lua"))()
    end)
    
    -- 2. If it worked, set Library; if not, wait 1 second and retry
    if success and result then
        Library = result
    else
        warn("Vision UI Lib failed to load, retrying...")
        task.wait(1)
    end
until Library ~= nil
