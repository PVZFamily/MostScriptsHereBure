MainSection:Button({
   Name = "INF jump",
   Callback = function()
      _G.infinjump = not _G.infinjump
      if not _G.infJumpConn then
          _G.infJumpConn = UIS.JumpRequest:Connect(function()
              if _G.infinjump then
                  local humanoid = getHumanoid()
                  if humanoid then humanoid:ChangeState("Jumping") end
              end
